# Server Configuration
PORT=3000
NODE_ENV=development

# Redis Configuration (for message queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_AUTH_TOKEN=your-auth-token-here

# SMS Configuration
SMS_PROVIDER=twilio
SMS_DEFAULT_RECIPIENTS=+1234567890,+0987654321

# Email Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_DEFAULT_RECIPIENTS=admin@company.com,manager@company.com

# WhatsApp Configuration
WHATSAPP_PROVIDER=twilio
WHATSAPP_DEFAULT_RECIPIENTS=+1234567890,+0987654321

# Twilio Configuration (if using Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@company.com

# AWS Configuration (if using AWS services)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_SNS_REGION=us-east-1
AWS_SES_REGION=us-east-1

# WhatsApp Business API Configuration
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your-access-token

# Third-party integration config (from main app)
# Main app base URL for fetching integration config by company/branch
MAIN_APP_URL=http://localhost:3000
# Same secret as main app INTEGRATION_CONFIG_API_KEY (header x-integration-api-key)
INTEGRATION_CONFIG_API_KEY=your-integration-config-api-key

# Hardcoded fallback: TextGuru (SMS) - used when no DB integration for SMS
# When set, webhook will send SMS via TextGuru for pos_save events
TEXTGURU_BASE_URL=https://www.textguru.in/api/v22.0
TEXTGURU_USERNAME=irujulerp
TEXTGURU_PASSWORD=your-password
TEXTGURU_SOURCE=IRUJUL
TEXTGURU_DLTTEMPID=1707175388615048157
TEXTGURU_MESSAGE_TEMPLATE=OTP:#OTP# for Price Change for item #emailProductCode#, Old Price : #emailCurrentPrice#, New Price: #emailNewPrice#, Customer : #emailContactName# -iRujulERP

# Hardcoded fallback: Powerstext (WhatsApp/RCS) - used when no DB integration for WhatsApp
POWERSTEXT_BASE_URL=https://rcs.powerstext.in
POWERSTEXT_PHONE_ID=873807449146537
POWERSTEXT_BEARER_TOKEN=your-bearer-token
POWERSTEXT_TEMPLATE_NAME=sale_invoice_25_
POWERSTEXT_LANGUAGE_CODE=en
POWERSTEXT_BODY_PARAM_KEYS=invoiceNumber,date
POWERSTEXT_HEADER_DOC_LINK=documentLink
POWERSTEXT_HEADER_DOC_FILENAME=filename
# Optional: template when no document (text-only, same body params). Use for reliable delivery without 24h rule.
# POWERSTEXT_TEMPLATE_NAME_NO_DOCUMENT=sale_invoice_text_only
# Optional: test document when job has no documentLink (to verify WhatsApp template sending). Same format as curl.
# POWERSTEXT_TEST_DOCUMENT_LINK=https://testerp.irujul.com/S3Files/2025-10-17/BM22.pdf
# POWERSTEXT_TEST_DOCUMENT_FILENAME=BM/25-26/435

#DB Configurations
MASTER_DB_HOST=3.110.243.213
MASTER_DB_PORT=5432
MASTER_DB_USERNAME=dbadmin
# MASTER_DB_PASSWORD = Welcome@1q3#
MASTER_DB_NAME=master_tenant_db